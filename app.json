{
  "expo": {
    "name": "Shiv Dairy Farm",
    "slug": "shiv-dairy-farm",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/brand-icon.png",
    "scheme": "shiv-dairy-farm",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.png"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/brand-icon.png",
        "monochromeImage": "./assets/images/brand-icon.png"
      },
      "splash": {
        "image": "./assets/images/brand-splash.png",
        "resizeMode": "contain"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/brand-icon.png"
    },
    "splash": {
      "image": "./assets/images/brand-splash.png",
      "resizeMode": "contain"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
